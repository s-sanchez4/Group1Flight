<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Group1Flight</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Group1Flight.styles.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>

@{
    // Count selections from the cookie for the badge
    var selectionCount = 0;
    var selectionCookie = Context.Request.Cookies["SelectedFlights"];
    if (!string.IsNullOrEmpty(selectionCookie))
    {
        selectionCount = selectionCookie.Split(',', StringSplitOptions.RemoveEmptyEntries).Length;
    }
}

<body> <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Flights" asp-action="Index">Group1Flight</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Flights" asp-action="Index">Home</a>
                        </li>
                        
                        <li class="nav-item">
                            <a class="nav-link text-dark position-relative" asp-area="" asp-controller="Flights" asp-action="Selections">
                                <i class="bi bi-bookmark-check"></i> Selections
                                @if (selectionCount > 0)
                                {
                                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                        @selectionCount
                                        <span class="visually-hidden">selected flights</span>
                                    </span>
                                }
                            </a>
                        </li>

                        <li class="nav-item ms-auto">
                            <a class="nav-link text-dark font-weight-bold" asp-area="Airlines" asp-controller="Flights" asp-action="Index">
                                <i class="bi bi-gear"></i> Manage Airlines
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Group1Flight - <a asp-area="" asp-controller="Flights" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>