@model Group1Flight.Models.FlightViewModel
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Available Flights";
}

<div class="text-center mb-4">
    <h1 class="display-4">Welcome to Group1Flight</h1>
    <p class="lead">View and search for available flights worldwide.</p>
</div>

<div class="container-fluid mt-4">
    <div class="row">
        
        <div class="col-md-3">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-filter"></i> Filter Flights</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Index" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">From</label>
                            <select asp-for="Flight.From" class="form-select" asp-items="ViewBag.FromCities">
                                <option value="">Anywhere</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">To</label>
                            <select asp-for="Flight.To" class="form-select" asp-items="ViewBag.ToCities">
                                <option value="">Anywhere</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Departure Date</label>
                            <input type="date" asp-for="Flight.Date" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Cabin Type</label>
                            <select asp-for="Flight.CabinType" class="form-select">
                                <option value="All">All</option>
                                <option value="Basic Economy">Basic Economy</option>
                                <option value="Economy">Economy</option>
                                <option value="Economy Plus">Economy Plus</option>
                                <option value="Business">Business</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 shadow-sm">Search Flights</button>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100 mt-2 btn-sm">Reset Filters</a>
                    </form>
                </div> </div> </div> <div class="col-md-9">
            <h3 class="mb-4">Results</h3>
            
            @if (ViewBag.Flights != null)
            {
                /* Notice: No '@' before foreach inside an existing @ block */
                foreach (var flight in (IEnumerable<Group1Flight.Models.Flight>)ViewBag.Flights)
                {
                    <div class="card mb-3 shadow-sm border-0">
                        <div class="card-body">
                            <div class="row align-items-center text-center">
                                
                                <div class="col-md-2 border-end">
                                    @if (flight.Airline != null && !string.IsNullOrEmpty(flight.Airline.ImageName))
                                    {
                                        <img src="~/images/@flight.Airline.ImageName" alt="@flight.Airline.Name" style="max-height: 50px;" class="img-fluid" />
                                        <div class="small fw-bold mt-1">@flight.Airline.Name</div>
                                    }
                                    else
                                    {
                                        <i class="bi bi-airplane-engines fs-1 text-secondary"></i>
                                    }
                                </div>

                                <div class="col-md-3">
                                    <div class="h5 mb-0">@flight.DepartureTime.ToString(@"hh\:mm")</div>
                                    <div class="text-muted fw-bold">@flight.From</div>
                                </div>

                                <div class="col-md-2">
                                     <i class="bi bi-arrow-right text-primary fs-3"></i>
                                </div>

                                <div class="col-md-3">
                                    <div class="h5 mb-0">@flight.ArrivalTime.ToString(@"hh\:mm")</div>
                                    <div class="text-muted fw-bold">@flight.To</div>
                                </div>

                                <div class="col-md-2 text-end">
                                    <div class="text-success h4 mb-0">$@flight.Price</div>
                                    <a asp-action="Details" asp-route-id="@flight.FlightId" class="btn btn-primary btn-sm w-100 shadow-sm mt-2">View Details</a>
                                </div>

                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-warning shadow-sm">
                    <i class="bi bi-exclamation-triangle"></i> No flights found for your criteria.
                </div>
            }
        </div> </div> </div> ```

