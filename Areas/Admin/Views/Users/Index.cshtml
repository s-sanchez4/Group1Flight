@model IEnumerable<Group1Flight.Models.Flight>
@{
    ViewData["Title"] = "Admin Dashboard";
    ViewData["BodyClass"] = "admin-bg";

}
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Airlines</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Group1Flight.styles.css" asp-append-version="true" />


        
    <div class="d-flex justify-content-end gap-2 mb-3">
    <a class="btn btn-warning" href="/">Home</a>
    <a class="btn btn-info" href="/Airlines/Flights">Airlines</a>
</div>

</head>
<div class="text-center">
    <h1 class="display-4">Admin Dashboard</h1>
    <p>Welcome to the Admin area. Here you can manage users and view rights and obligations.</p>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">User Management</h5>
                    <p class="card-text">Manage user accounts and permissions.</p>
                    <a asp-area="Admin" asp-controller="Users" asp-action="Index" class="btn btn-primary">Manage Users</a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Rights and Obligations</h5>
                    <p class="card-text">View all rights and obligations.</p>
                    <a href="#" class="btn btn-secondary">View</a>
                </div>
            </div>
        </div>
    </div>
</div>
