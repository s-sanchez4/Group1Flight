@model IEnumerable<Group1Flight.Models.Flight>

@{
    ViewData["Title"] = "Airlines Dashboard";
    ViewData["BodyClass"] = "airlines-bg";
}

<div class="container mt-4">
    <div class="d-flex justify-content-end gap-2 mb-3">
        <a class="btn btn-warning shadow-sm" href="/">Home</a>
        <a class="btn btn-info shadow-sm" href="/Admin/Users">Admin</a>
    </div>

    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Airlines Dashboard</h1>
        <p class="lead">Manage flight schedules, details, and airline regulations.</p>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm border-0">
                <div class="card-body d-flex justify-content-between align-items-center bg-light">
                    <div>
                        <h5 class="card-title mb-1">Flight Inventory</h5>
                        <p class="card-text text-muted mb-0">Total Flights Registered: @Model?.Count()</p>
                    </div>
                    <a asp-action="Create" class="btn btn-success">
                        <i class="bi bi-plus-circle"></i> Add New Flight
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Code</th>
                            <th>Airline</th>
                            <th>From/To</th>
                            <th>Schedule</th>
                            <th>Aircraft</th>
                            <th>Price</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold">@item.FlightCode</td>
                                    <td>
                                        @if (item.Airline != null)
                                        {
                                            <div class="d-flex align-items-center">
                                                <img src="~/images/@item.Airline.ImageName" style="height:25px" class="me-2" alt="Logo" />
                                                <span>@item.Airline.Name</span>
                                            </div>
                                        }
                                    </td>
                                    <td>@item.From <i class="bi bi-arrow-right text-primary"></i> @item.To</td>
                                    <td>
                                        <div class="small">@item.Date.ToShortDateString()</div>
                                        <div class="fw-bold">@item.DepartureTime.ToString(@"hh\:mm")</div>
                                    </td>
                                    <td>
                                        <span class="badge rounded-pill bg-info text-dark">@item.AircraftType</span>
                                    </td>
                                    <td class="text-success fw-bold">$@item.Price</td>
                                    <td class="text-center">
                                        <div class="btn-group shadow-sm">
                                            <a asp-action="Edit" asp-route-id="@item.FlightId" class="btn btn-sm btn-outline-primary">Edit</a>
                                            <a asp-action="Delete" asp-route-id="@item.FlightId" class="btn btn-sm btn-outline-danger">Delete</a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="7" class="text-center py-4 text-muted">
                                    No flights currently in the database.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6 mx-auto text-center">
            <div class="card shadow-sm">
                <div class="card-body">