@model Group1Flight.Models.Flight

@{
    ViewData["Title"] = "Delete Flight";
    ViewData["BodyClass"] = "airlines-bg";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card border-danger shadow">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Confirm Deletion</h4>
                </div>
                <div class="card-body text-center">
                    <i class="bi bi-exclamation-triangle text-danger display-1"></i>
                    <h3 class="mt-3">Are you sure?</h3>
                    <p class="text-muted">You are about to delete flight <strong>@Model.FlightCode</strong> from @Model.From to @Model.To.</p>
                    
                    <div class="alert alert-warning py-2 small">
                        This action cannot be undone and will remove the flight from all client searches.
                    </div>

                    <form asp-area="Airlines" asp-controller="Flights" asp-action="Delete" asp-route-id="@Model.FlightId" method="post">
    <input type="hidden" asp-for="FlightId" />
                        <input type="hidden" asp-for="FlightId" />
                        <div class="d-grid gap-2 d-md-block">
                            <a asp-action="Index" class="btn btn-secondary">No, Keep It</a>
                            <button type="submit" class="btn btn-danger px-4">Yes, Delete Flight</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>